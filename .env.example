# ==========================================
# 量化选股日历系统 - 环境配置模板
# 使用前请复制为 .env 并修改配置
# ==========================================

# 服务器配置
HOST=0.0.0.0
PORT=8000
DEBUG=True

# JWT 认证配置（生产环境请修改为随机字符串）
SECRET_KEY=quant-calendar-secret-key-change-in-production-2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Tushare API 配置（必填，去 https://tushare.pro/ 注册获取）
TUSHARE_TOKEN=your_tushare_token_here

# Redis 配置 (用于限流和缓存，可选)
REDIS_URL=redis://localhost:6379/0

# 数据库配置
DATABASE_URL=sqlite:///./data/quant_calendar.db

# CORS 配置
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# 飞书 Webhook 配置 (可选，用于推送通知)
FEISHU_WEBHOOK_URL=

# 策略数据目录配置
# 指向包含 CSV 数据文件的目录
QUANT_DATA_DIR=../qresult
