# ==========================================
# 量化选股日历系统 - 环境配置模板
# 使用前请复制为 .env 并修改配置
#   cp .env.example .env
# ==========================================

# 服务器配置
HOST=0.0.0.0
PORT=8000
DEBUG=True

# JWT 认证密钥（生产环境务必修改为随机字符串）
SECRET_KEY=quant-calendar-secret-key-change-in-production-2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Tushare API（必填，去 https://tushare.pro/ 注册获取）
TUSHARE_TOKEN=your_tushare_token_here

# 多数据源配置 (v1.8.0+)
SXSC_TUSHARE_TOKEN=
SXSC_TUSHARE_ENABLED=True
AKSHARE_ENABLED=True

# Redis（可选，用于限流和缓存）
REDIS_URL=redis://localhost:6379/0

# 数据库
DATABASE_URL=sqlite:///./data/quant_calendar.db

# CORS
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# 飞书 Webhook (可选，用于推送通知)
FEISHU_WEBHOOK_URL=

# 策略数据目录（指向包含 CSV 数据文件的目录）
QUANT_DATA_DIR=../qresult
